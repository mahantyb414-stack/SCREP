# Environment variables for local development
# Copy this to .env and fill in your values

# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# Render deployment
RENDER_API_URL=https://scraping-delhi.onrender.com

# Scraper configuration
MAX_WORKERS=4
CTX_POOL_SIZE=3
LOCATION_WORKERS=2

# Data configuration
DATA_DIR=./Data
OUTPUT_DIR=./outputs

# Logging
LOG_LEVEL=INFO
